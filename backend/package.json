{
  "name": "@fieldsaver/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:rollback:all": "knex --knexfile knexfile.ts migrate:rollback --all",
    "migrate:status": "knex --knexfile knexfile.ts migrate:status",
    "migrate:unlock": "knex --knexfile knexfile.ts migrate:unlock",
    "seed": "knex --knexfile knexfile.ts seed:run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "knex-stringcase": "1.6.0",
    "pg": "^8.11.0",
    "pino-http": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@fieldsaver/shared": "*",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^1.3.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
